# ===========================================
# Whisper-Input-Next — 本地 whisper.cpp 配置
# 由 whisper-input-next-mac-kit 安装时生成（install.sh 会填好下面两个路径）
# ===========================================

# 服务平台（必须是合法值，否则启动 ValueError）
SERVICE_PLATFORM=openai&local

# Ctrl+F / 右⌘ 主力后端：local（配合补丁，Ctrl+F 和 Ctrl+I 都走本地）
TRANSCRIPTION_SERVICE=local

# 本地 whisper.cpp（由安装脚本按你的机器填好）
WHISPER_CLI_PATH=__WHISPER_CLI_PATH__
WHISPER_MODEL_PATH=__WHISPER_MODEL_PATH__

# 豆包（未使用，留空 → 自动禁用）
DOUBAO_APP_KEY=
DOUBAO_ACCESS_KEY=

# ===========================================
# 占位 key —— 本地模式下都不会被真正调用，但启动时这三处构造函数要求它们非空，
# 否则程序直接崩溃（均已实测）：
#   1) WhisperProcessor: assert OFFICIAL_OPENAI_API_KEY
#   2) SymbolProcessor : OpenAI(api_key=GROQ_API_KEY) 客户端要求非空
#   3) KimiProcessor   : if not KIMI_API_KEY: raise ValueError（LocalWhisperProcessor 无条件构造它）
# 保持原样即可，无需填真实值。
# ===========================================
OFFICIAL_OPENAI_API_KEY=sk-placeholder-not-used
GROQ_API_KEY=gsk-placeholder-not-used
KIMI_API_KEY=kimi-placeholder-not-used

# 键盘 & 平台
TRANSCRIPTIONS_BUTTON=f
TRANSLATIONS_BUTTON=ctrl
SYSTEM_PLATFORM=mac

# 功能开关
CONVERT_TO_SIMPLIFIED=false
ADD_SYMBOL=false
OPTIMIZE_RESULT=false
ENABLE_KIMI_POLISH=false
AUTO_RETRY_LIMIT=5

# 本地 whisper 标点引导 prompt（prompt 带标点 → 输出带标点；置空则不加标点）
WHISPER_PROMPT=以下是一段普通话，请正确断句并加上标点符号。
# 把与中文相邻的半角标点转全角（，。！？）；false 关闭
WHISPER_FULLWIDTH_PUNCT=true

# 录音归档自动清理：保留多少小时（启动时 + 定期删除超期 WAV；设 <0 则不清理）
AUDIO_ARCHIVE_RETENTION_HOURS=24
# 定期清理的间隔（小时）
AUDIO_ARCHIVE_CLEANUP_INTERVAL_HOURS=6

# 提示音（macOS 系统音名，见 /System/Library/Sounds，如 Submarine/Glass/Ping/Pop/Hero...）
SOUND_START=Submarine
SOUND_STOP=Submarine
SOUND_DONE=Glass
SOUND_ERROR=Basso
SOUND_WARNING=Funk

# 底部居中的听写指示器浮窗；false 关闭
SHOW_INDICATOR=true
# 指示器风格：ring（呼吸光环）| capsule（胶囊条，录完收起、成功变绿）
INDICATOR_STYLE=ring

# 转录后本地 LLM 精炼（可选）：用本地 Ollama 模型把听写结果整理得更通顺/简洁。
# 需先装 Ollama 并 `ollama pull` 模型；默认关；Ollama 没开/超时会原样返回，不卡听写。
POLISH_ENABLED=false
# 模型（Ollama 里的 tag）：glm4（GLM-4-9B，质量/体量均衡，推荐）| qwen2.5:3b（更轻更快）等
POLISH_MODEL=glm4
# 力度：light（保真，只修标点/错字）| concise（去口语赘述，更简洁）
POLISH_MODE=light
# 超时秒数（超时退回原始转录）
POLISH_TIMEOUT=20
OLLAMA_URL=http://localhost:11434

# 防卡死：看门狗（卡在忙碌态超阈值→把全线程栈写进 logs/freeze_diagnostics.log）
WATCHDOG_ENABLED=true
WATCHDOG_PROCESSING_SECONDS=45   # 转录态卡多久算异常（正常才几秒）
WATCHDOG_RECORDING_SECONDS=180   # 录音态阈值放宽（长听写可能几分钟）
# whisper-cli 子进程超时（秒）：卡住会被杀掉并报错恢复，而非无限阻塞
WHISPER_SUBPROCESS_TIMEOUT=90
