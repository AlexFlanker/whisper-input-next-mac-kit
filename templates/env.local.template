# ===========================================
# Whisper-Input-Next — 本地 whisper.cpp 配置
# 由 whisper-input-next-mac-kit 安装时生成（install.sh 会填好下面两个路径）
# ===========================================

# 服务平台（必须是合法值，否则启动 ValueError）
SERVICE_PLATFORM=openai&local

# Ctrl+F / 右⌘ 主力后端：local（配合补丁，Ctrl+F 和 Ctrl+I 都走本地）
TRANSCRIPTION_SERVICE=local

# 本地 whisper.cpp（由安装脚本按你的机器填好）
WHISPER_CLI_PATH=__WHISPER_CLI_PATH__
WHISPER_MODEL_PATH=__WHISPER_MODEL_PATH__

# 豆包（未使用，留空 → 自动禁用）
DOUBAO_APP_KEY=
DOUBAO_ACCESS_KEY=

# ===========================================
# 占位 key —— 本地模式下都不会被真正调用，但启动时这三处构造函数要求它们非空，
# 否则程序直接崩溃（均已实测）：
#   1) WhisperProcessor: assert OFFICIAL_OPENAI_API_KEY
#   2) SymbolProcessor : OpenAI(api_key=GROQ_API_KEY) 客户端要求非空
#   3) KimiProcessor   : if not KIMI_API_KEY: raise ValueError（LocalWhisperProcessor 无条件构造它）
# 保持原样即可，无需填真实值。
# ===========================================
OFFICIAL_OPENAI_API_KEY=sk-placeholder-not-used
GROQ_API_KEY=gsk-placeholder-not-used
KIMI_API_KEY=kimi-placeholder-not-used

# 键盘 & 平台
TRANSCRIPTIONS_BUTTON=f
TRANSLATIONS_BUTTON=ctrl
SYSTEM_PLATFORM=mac

# 功能开关
CONVERT_TO_SIMPLIFIED=false
ADD_SYMBOL=false
OPTIMIZE_RESULT=false
ENABLE_KIMI_POLISH=false
AUTO_RETRY_LIMIT=5
